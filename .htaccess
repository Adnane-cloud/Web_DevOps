RewriteEngine On
RewriteBase /

# Handle root URL explicitly (prevents 403 Forbidden on homepage)
RewriteRule ^$ public/index.php [L]

# Serve CSS, JS, and media files directly from the public/ folder
# This replaces the unreliable DOCUMENT_ROOT file-check used before
RewriteRule ^(css|js|uploads|images)/(.+)$ public/$1/$2 [L]

# Route all other requests through the PHP router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ public/index.php?url=$1 [L,QSA]
